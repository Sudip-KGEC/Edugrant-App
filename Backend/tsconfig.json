{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "rootDir": "./api",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "lib": ["ESNext"],
    "moduleResolution": "node"
  },
  "include": ["api/**/*.ts"],
  "exclude": ["node_modules"]
}